        :root {
            --primary: #1a1a2e;
            --secondary: #16213e;
            --accent: #0f3460;
            --highlight: #e94560;
            --text: #333;
            --text-light: #666;
            --bg: #f8f9fa;
            --white: #ffffff;
            --border: #e0e0e0;
        }

        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: var(--bg);
            color: var(--text);
            line-height: 1.6;
            -webkit-font-smoothing: antialiased;
        }

        .page {
            max-width: 210mm;
            min-height: 297mm;
            margin: 0 auto;
            background: var(--white);
            box-shadow: 0 0 20px rgba(0,0,0,0.1);
        }

        /* Header */
        .header {
            background: var(--primary);
            color: var(--white);
            padding: 40px 50px;
            position: relative;
            overflow: hidden;
        }

        .header::before {
            content: '';
            position: absolute;
            top: -50%;
            right: -20%;
            width: 60%;
            height: 200%;
            background: var(--secondary);
            transform: rotate(15deg);
            opacity: 0.5;
        }

        .header::after {
            content: '';
            position: absolute;
            bottom: 0;
            left: 0;
            width: 100%;
            height: 4px;
            background: var(--highlight);
        }

        .header-content {
            position: relative;
            z-index: 1;
        }

        .name {
            font-size: 2.4em;
            font-weight: 700;
            letter-spacing: -0.5px;
            margin-bottom: 8px;
        }

        .title {
            font-size: 1.1em;
            color: #a0aec0;
            font-weight: 400;
            margin-bottom: 20px;
            letter-spacing: 0.5px;
        }

        .contact-bar {
            display: flex;
            flex-wrap: wrap;
            gap: 20px;
            font-size: 0.9em;
        }

        .contact-item {
            display: flex;
            align-items: center;
            gap: 8px;
            color: #cbd5e0;
        }

        .contact-item svg {
            width: 16px;
            height: 16px;
            fill: var(--highlight);
        }

        .contact-item a {
            color: #cbd5e0;
            text-decoration: none;
            transition: color 0.2s;
        }

        .contact-item a:hover {
            color: var(--highlight);
        }

        /* Main Content */
        .main {
            padding: 35px 50px 40px;
        }

        .two-column {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 35px;
        }

        .left-col {
            border-right: 1px solid var(--border);
            padding-right: 35px;
        }

        .right-col {
            padding-left: 0;
        }

        /* Section Styling */
        .section {
            margin-bottom: 28px;
        }

        .section-title {
            font-size: 0.85em;
            text-transform: uppercase;
            letter-spacing: 2px;
            color: var(--highlight);
            font-weight: 700;
            margin-bottom: 14px;
            padding-bottom: 8px;
            border-bottom: 2px solid var(--highlight);
            display: inline-block;
        }

        /* Summary */
        .summary-text {
            font-size: 0.95em;
            line-height: 1.7;
            color: var(--text);
            text-align: justify;
        }

        /* Experience */
        .experience-item {
            margin-bottom: 22px;
            position: relative;
            padding-left: 16px;
            border-left: 2px solid var(--border);
        }

        .experience-item::before {
            content: '';
            position: absolute;
            left: -5px;
            top: 6px;
            width: 8px;
            height: 8px;
            border-radius: 50%;
            background: var(--highlight);
        }

        .exp-header {
            display: flex;
            justify-content: space-between;
            align-items: baseline;
            flex-wrap: wrap;
            gap: 5px;
        }

        .exp-title {
            font-weight: 700;
            font-size: 1em;
            color: var(--primary);
        }

        .exp-date {
            font-size: 0.8em;
            color: var(--text-light);
            font-weight: 500;
        }

        .exp-company {
            font-size: 0.9em;
            color: var(--accent);
            font-weight: 600;
            margin-bottom: 6px;
        }

        .exp-list {
            list-style: none;
            padding: 0;
        }

        .exp-list li {
            font-size: 0.88em;
            color: var(--text);
            margin-bottom: 5px;
            padding-left: 14px;
            position: relative;
            line-height: 1.5;
        }

        .exp-list li::before {
            content: '›';
            position: absolute;
            left: 0;
            color: var(--highlight);
            font-weight: 700;
        }

        /* Projects */
